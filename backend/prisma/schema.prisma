generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  movements      StockMovement[]
  posBills       PosBill[]
  customerOrders Order[] @relation("CustomerOrders")
  staffOrders    Order[] @relation("StaffOrders")
  sentMessages   OrderMessage[] @relation("SentMessages")
  audits         AuditLog[] @relation("UserAudits")
}

enum Role {
  OWNER
  PARTNER
  MANAGER
  STAFF
  DELIVERY
  CUSTOMER
}

model Store {
  id          String   @id @default(uuid())
  name        String
  location    String?
  latitude    Float?
  longitude   Float?
  operatingRadiusKm Float @default(3.0)
  gstin       String?
  isActive    Boolean  @default(true)
  users       User[]
  products    Product[]
  inventory   Inventory[]
  movements   StockMovement[]
  posBills    PosBill[]
  orders      Order[]
  supplierConnections StoreSupplierConnection[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Onboarding & Payment Details
  bankAccountNumber String?
  bankRoutingNumber String?
  taxId             String?

  purchaseOrders    PurchaseOrder[]
}

model Product {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  barcode        String?
  internalSku    String   @unique
  name           String
  description    String?
  category       String?
  mrp            Float
  sellingPrice   Float
  purchaseCost   Float?
  gstRate        Float    @default(0)
  imageUrl       String?
  isActive       Boolean  @default(true)
  inventory      Inventory[]
  movements      StockMovement[]
  posBillItems   PosBillItem[]
  orderItems     OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierProducts SupplierProduct[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storeId])
}

model Inventory {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  batchNo        String?
  expiryDate     DateTime?
  onHandQty      Int      @default(0)
  reservedQty    Int      @default(0)
  blockedQty     Int      @default(0)
  movements      StockMovement[]
  
  // Available Qty = onHandQty - reservedQty - blockedQty
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, productId, batchNo])
}

model StockMovement {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  inventoryId    String
  inventory      Inventory @relation(fields: [inventoryId], references: [id])
  type           MovementType
  quantityChange Int
  sourceType     String?  // e.g., "ONLINE_ORDER", "POS_SALE", "SUPPLIER_DELIVERY"
  sourceId       String?
  reason         String?
  staffId        String?
  staff          User?    @relation(fields: [staffId], references: [id])
  createdAt      DateTime @default(now())
}

enum MovementType {
  STOCK_RECEIVED
  POS_SALE
  ONLINE_ORDER_RESERVED
  ONLINE_ORDER_PICKED
  ORDER_CANCELLED
  RETURN_ACCEPTED
  DAMAGED
  EXPIRED
  MANUAL_ADJUSTMENT
  STOCK_COUNT_CORRECTION
}

enum BillStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

model PosBill {
  id        String        @id @default(uuid())
  storeId   String
  store     Store         @relation(fields: [storeId], references: [id])
  staffId   String?
  staff     User?         @relation(fields: [staffId], references: [id])
  status    BillStatus    @default(DRAFT)
  subtotal  Float         @default(0)
  gst       Float         @default(0)
  total     Float         @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  items     PosBillItem[]
  payments  PosPayment[]
}

model PosBillItem {
  id          String   @id @default(uuid())
  billId      String
  bill        PosBill  @relation(fields: [billId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  priceAtSale Float
  gstAtSale   Float    @default(0)
  createdAt   DateTime @default(now())
}

model PosPayment {
  id            String        @id @default(uuid())
  billId        String
  bill          PosBill       @relation(fields: [billId], references: [id])
  amount        Float
  method        PaymentMethod
  referenceId   String?
  createdAt     DateTime      @default(now())
}

// -----------------------------------------------------
// Sprint 3: Consumer Orders & Supplier Network
// -----------------------------------------------------

enum OrderStatus {
  PAYMENT_PENDING
  PAID
  PICKING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id          String        @id @default(uuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id])
  customerId  String
  customer    User          @relation("CustomerOrders", fields: [customerId], references: [id])
  staffId     String?       // Picker
  staff       User?         @relation("StaffOrders", fields: [staffId], references: [id])
  status      OrderStatus   @default(PAYMENT_PENDING)
  totalAmount Float         @default(0)
  deliveryFee Float         @default(0)
  deliveryAddress String?
  deliveryLat Float?
  deliveryLng Float?
  requireOtp  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       OrderItem[]
  messages    OrderMessage[]
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
}

model Supplier {
  id           String   @id @default(uuid())
  name         String
  contactEmail String?
  contactPhone String?
  categories   String?  // comma separated or JSON
  rating       Float    @default(5.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeConnections StoreSupplierConnection[]
  purchaseOrders   PurchaseOrder[]
  supplierProducts SupplierProduct[]
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  REJECTED
}

model StoreSupplierConnection {
  id         String           @id @default(uuid())
  storeId    String
  store      Store            @relation(fields: [storeId], references: [id])
  supplierId String
  supplier   Supplier         @relation(fields: [supplierId], references: [id])
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([storeId, supplierId])
}

model OrderMessage {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  user       User?    @relation("UserAudits", fields: [userId], references: [id])
  details    String?
  createdAt  DateTime @default(now())
}

enum POStatus {
  CREATED
  SENT
  ACCEPTED
  PARTIALLY_ACCEPTED
  DELIVERED
  REJECTED
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  storeId              String
  store                Store               @relation(fields: [storeId], references: [id])
  supplierId           String
  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  status               POStatus            @default(CREATED)
  expectedDeliveryDate DateTime?
  totalAmount          Float               @default(0)
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  
  items                PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id])
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantity         Int
  acceptedQuantity Int           @default(0)
  receivedQuantity Int           @default(0)
  purchasePrice    Float
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model SupplierProduct {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, productId])
}
